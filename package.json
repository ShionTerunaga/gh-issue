{
  "name": "gh-issue",
  "version": "0.0.0",
  "description": "A command line tool for GitHub issues.",
  "homepage": "https://github.com/OWNER/gh-issue#readme",
  "bugs": {
    "url": "https://github.com/OWNER/gh-issue/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OWNER/gh-issue.git"
  },
  "bin": {
    "gh-issue": "./dist/index.js"
  },
  "files": [
    "dist",
    "template",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "exports": "./dist/index.js",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "lint": "oxlint .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "check": "pnpm lint && pnpm format:check && pnpm test && pnpm build",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "gh": "^2.8.9",
    "ts-shared": "github:ShionTerunaga/ts-shared#release"
  },
  "devDependencies": {
    "@types/node": "latest",
    "oxfmt": "latest",
    "oxlint": "latest",
    "typescript": "latest",
    "vite": "latest",
    "vitest": "latest"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.10.0"
}
