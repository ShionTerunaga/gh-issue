{
  "name": "gh-issue",
  "version": "0.3.2",
  "description": "A command line tool for GitHub issues.",
  "homepage": "https://github.com/ShionTerunaga/gh-issue#readme",
  "bugs": {
    "url": "https://github.com/ShionTerunaga/gh-issue/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ShionTerunaga/gh-issue.git"
  },
  "bin": {
    "gh-issue": "./dist/index.mjs"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "exports": "./dist/index.mjs",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "vite build && pnpm copy:template",
    "changeset": "changeset",
    "copy:template": "node --experimental-strip-types scripts/copy-template.ts",
    "test": "vitest run",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "check": "pnpm lint && pnpm format:check && pnpm test && pnpm build",
    "prepack": "pnpm build",
    "initial": "lefthook install",
    "version:packages": "changeset version",
    "gh-init": "gh-issue init",
    "gh-create": "gh-issue create",
    "gh-send": "gh-issue send"
  },
  "dependencies": {
    "@clack/prompts": "^1.3.0",
    "@types/prompts": "^2.4.9",
    "commander": "^14.0.3",
    "fast-glob": "^3.3.3",
    "gh-issue": "github:ShionTerunaga/gh-issue#release",
    "js-yaml": "^4.1.1",
    "picocolors": "^1.1.1",
    "ts-shared": "github:ShionTerunaga/ts-shared#release",
    "valibot": "^1.3.1",
    "yaml-parser": "^3.5.3"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/node": "25.6.0",
    "lefthook": "^2.1.6",
    "oxfmt": "0.47.0",
    "oxlint": "1.62.0",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "vite": "8.0.10",
    "vitest": "4.1.5"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.18.3"
}
